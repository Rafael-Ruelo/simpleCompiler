lalagyan a;
lalagyan b;
lalagyan sum;
lalagyan diff;
lalagyan product;
lalagyan quotient;
lalagyan complex_result;

ilagay a;
ilagay b;

sum     = a + b;
diff    = a - b;
product = a * b;
quotient = a / b;

complex_result = a * a + 2 * a * b + b * b;

kinalabasan sum;
kinalabasan diff;
kinalabasan product;
kinalabasan quotient;
kinalabasan complex_result;
